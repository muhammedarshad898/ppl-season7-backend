# RENAME or COPY this file to ".env" (without .example) in this folder.
# The app only loads .env — it does NOT read .env.example.
# MongoDB connection (use any of these)
# Example: mongodb://localhost:27017/auction_system
# If not set: app runs in memory mode (no DB). Players and teams come from
# backend/src/config/defaultData.js and are kept in RAM until restart.
MONGODB_URI=mongodb://localhost:27017/auction_system

# Alternative env var names (some hosts use these)
# MONGO_URI=mongodb://localhost:27017/auction_system
# DATABASE_URL=mongodb://localhost:27017/auction_system

PORT=5000
JWT_SECRET=change-this-secret
# Admin session duration: 7d, 24h, 12h, 8h, etc.
JWT_EXPIRES_IN=7d
# Comma-separated origins for CORS. Dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTO_BACKUP_INTERVAL_MS=30000
# Set true on production if you want startup to fail when DB is missing.
REQUIRE_DB=false
